# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your apps → Config
# .env.local is gitignored — NEVER commit real keys to source control.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Flutterwave (payments)
VITE_FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
